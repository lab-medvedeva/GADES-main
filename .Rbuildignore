# R CMD build excludes — keep the tarball to package material only (ADR follow-up,
# candidate 6). The repo doubles as a research monorepo (benchmarks, datasets,
# notebooks, vendored libs); none of that belongs in the installable package.

# --- build artifacts / caches ---
^build$
^build_test$
^lib$
^inst/libs$
^src/.*\.o$
^src/.*\.so$
^src/.*\.bak.*$
^.*\.bak.*$
^.*_pre.*\.bak$

# --- vendored / benchmark third-party ---
^arrayfire$
^armadillo$
^GADES-main$
^GADESBachelor$
^scientific-agent-skills$
^__MACOSX$
^nsightsystems.*\.run$

# --- benchmark / run / validation scripts (not package API) ---
^bench_.*$
^run_.*$
^rebench_.*$
^get_all_different_benchmarks\.sh$
^test_arrayfire.*$
^test_armadillo.*$
^test_cublas.*$
^af_spearman.*$
^arma_spearman.*$
^manhattan_tiled_proto.*$
^validate.*\.R$
^debug_.*\.R$
^test_.*\.R$
^bench.*\.R$
^calculate\.R$
^estimate_block\.R$
^run_dense\.R$
^classify_blocks\.py$
^count_density\.py$
^predict_wall_timed\.py$
^plot_scatter_datasets\.py$
^generate_matrices_sparse\.py$
^select_top.*\.py$
^python$
^python_benchmarking\.py$
^prototype_cublas$
^reproduction$
^plans$
^tools$

# --- datasets & generated data ---
^Datasets$
^Generated.*$
^HugeDatasets$
^RealDatasets$
^matrices$
^ml-20m.*$
^.*_tmp$
^.*\.mtx$
^.*\.csv$
^.*\.json$
^.*\.json\.gz$
^.*\.zip$
^.*\.rating$
^.*\.txt$
^Camp.*$
^Chen\.mtx$
^HLCA.*$
^HSC.*$
^PBMC.*$
^snRNA_.*$
^GSE.*$

# --- notebooks / figures / logs / results ---
^.*\.ipynb$
^\.ipynb_checkpoints$
^.*\.png$
^.*\.jpeg$
^.*\.jpg$
^.*\.pdf$
^charts$
^cluster_charts$
^png-plots$
^pdf-plots$
^final$
^final_scores$
^scores$
^logs$
^log\.txt$
^results.*$
^out.*$
^commands.*\.txt$
^paper$
^related_work_rapids\.tex$
^refs_rapids\.bib$
^results_oom.*$
^table_datasets\.tex$
^predicted_.*\.csv$
^spearman_ties_sweep\.csv$

# --- dev / editor / meta ---
^\.git.*$
^\.vscode$
^\.claude$
^CLAUDE\.md$
^CONTEXT\.md$
^HANDOFF\.md$
^FIRST_PROMPT\.txt$
^ARRAYFIRE_RUN\.md$
^cmake-test\.txt$
^main\.o$
^test$
^test\.cpp$
^test\.R$
^pam50_dist.*\.R$
^install\.sh$
^makeSparse\.sh$
^\.dockerignore$
^\.Rhistory$
